{
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/crm",
    "Audience": "crm-api",
    "RequireHttpsMetadata": false
  },
  "ConnectionStrings": {
    "Default": "Host=postgres;Port=5432;Database=crm_clientes;Username=crm;Password=crm@2026"
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:4200"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}